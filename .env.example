# Copy to `.env.local` (gitignored) and adjust for your environment.

# Base URL the SPA uses to reach the API. Default is `/api` (same-origin).
# Set this only if the API is served from a different path/origin AND that
# origin is allowlisted by the API's CORS configuration.
# VITE_API_BASE=/api

# Dev-only: target backend for the Vite `/api` dev proxy. When set, `npm run dev`
# proxies same-origin `/api/*` requests to this address so you can develop
# against a locally running wyrtloom-dashboard-api. Has no effect on `build`.
# VITE_DEV_API_TARGET=http://127.0.0.1:7878
